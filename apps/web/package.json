{
  "name": "@ecoctrl/web",
  "version": "0.7.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --port 8080",
    "build": "react-router build && cp .env.example build/client/.env.example",
    "preview": "pnpm build && pnpm dlx dotenv-cli -e .env.local -- pnpm dlx serve build/client -p 8081 -s",
    "start": "pnpm build && pnpm dlx dotenv-cli -e .env.local -- pnpm dlx serve build/client -p 8081 -s",
    "typecheck": "react-router typegen && tsc",
    "fmt": "vp fmt -c $(pwd)/.oxfmtrc.json",
    "check:fix": "pnpm fmt && vp lint --fix",
    "env:sync": "tsx ../../packages/shared/scripts/gen-env-example.ts",
    "env:check": "tsx ../../packages/shared/scripts/gen-env-example.ts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babylonjs/core": "catalog:",
    "@babylonjs/loaders": "catalog:",
    "@base-ui/react": "catalog:",
    "@ecoctrl/ui": "workspace:*",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@react-router/node": "7.14.0",
    "clsx": "catalog:",
    "isbot": "^5",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "7.14.0",
    "recharts": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@ecoctrl/shared": "workspace:*",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
