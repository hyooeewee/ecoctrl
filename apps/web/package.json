{
  "name": "@ecoctrl/web",
  "version": "0.4.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev --port 8080",
    "build": "react-router build && cp .env.example build/client/.env.example",
    "preview": "pnpm build && pnpm dlx dotenv-cli -e .env.local -- pnpm dlx serve build/client -p 8081 -s",
    "start": "pnpm build && pnpm dlx dotenv-cli -e .env.local -- pnpm dlx serve build/client -p 8081 -s",
    "typecheck": "react-router typegen && tsc",
    "fmt": "vp fmt -c $(pwd)/.oxfmtrc.json",
    "check:fix": "pnpm fmt && vp lint --fix",
    "env:sync": "node ../../packages/shared/scripts/gen-env-example.mjs",
    "env:check": "node ../../packages/shared/scripts/gen-env-example.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babylonjs/core": "^9.2.1",
    "@babylonjs/loaders": "^9.2.1",
    "@base-ui/react": "catalog:",
    "@ecoctrl/ui": "workspace:*",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@react-router/node": "7.14.0",
    "clsx": "catalog:",
    "isbot": "^5",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "7.14.0",
    "recharts": "catalog:",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@ecoctrl/shared": "workspace:*",
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "jsdom": "^26.1.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
