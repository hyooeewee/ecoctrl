{
  "name": "@ecoctrl/admin",
  "version": "0.4.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build && cp .env.example dist/",
    "preview": "vp preview",
    "start": "pnpm build && pnpm dlx dotenv-cli -e .env.local -- pnpm dlx serve dist -p 4173",
    "fmt": "vp fmt -c $(pwd)/.oxfmtrc.json",
    "check": "pnpm fmt && vp lint",
    "env:sync": "tsx ../../packages/shared/scripts/gen-env-example.ts",
    "env:check": "tsx ../../packages/shared/scripts/gen-env-example.ts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "catalog:",
    "@google/model-viewer": "^4.2.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "jsep": "^1.4.0",
    "lucide-react": "catalog:",
    "motion": "^12.23.24",
    "pg-boss": "^12.18.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "recharts": "catalog:",
    "shadcn": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@ecoctrl/shared": "workspace:*",
    "@ecoctrl/ui": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "@vitest/ui": "4.1.5",
    "@vitest/coverage-v8": "4.1.5",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^26.1.0"
  }
}
