{
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "title": "请求方法",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "default": "GET"
    },
    "url": {
      "type": "string",
      "title": "URL",
      "format": "uri"
    },
    "headers": {
      "type": "object",
      "title": "请求头"
    },
    "body": {
      "type": "object",
      "title": "请求体"
    },
    "timeoutMs": {
      "type": "number",
      "title": "超时 (毫秒)",
      "default": 10000
    },
    "retry": {
      "type": "number",
      "title": "重试次数",
      "default": 0
    }
  },
  "required": ["url"]
}
