{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Cron Trigger Config",
  "properties": {
    "cron": {
      "type": "string",
      "title": "Cron Expression",
      "description": "Cron expression to schedule the trigger (e.g. 0 9 * * *)"
    },
    "timezone": {
      "type": "string",
      "title": "Timezone",
      "default": "Asia/Shanghai",
      "description": "IANA timezone identifier (e.g. Asia/Shanghai)"
    }
  },
  "required": ["cron"]
}
