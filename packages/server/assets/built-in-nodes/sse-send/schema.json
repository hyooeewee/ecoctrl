{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "SSE 推送配置",
  "properties": {
    "eventType": {
      "type": "string",
      "title": "事件类型",
      "description": "SSE 事件类型标识",
      "default": "update:widgets"
    },
    "payload": {
      "type": "string",
      "title": "事件内容 (JSON)",
      "description": "JSON 格式的事件负载，支持 {{表达式}}。示例：{\"metric_key\": \"{{point-read.value}}\", \"data\": {}}",
      "default": "{}",
      "format": "textarea"
    },
    "targetMode": {
      "type": "string",
      "title": "发送目标",
      "enum": ["broadcast", "trigger", "user"],
      "default": "broadcast"
    },
    "targetUserId": {
      "type": "string",
      "title": "目标用户 ID",
      "description": "仅当发送目标为 \"指定用户\" 时生效，支持 {{表达式}}"
    },
    "eventId": {
      "type": "string",
      "title": "事件 ID",
      "description": "事件唯一标识，留空时默认使用当前时间戳"
    }
  },
  "required": ["eventType", "payload", "targetMode"],
  "outputs": {
    "type": "object",
    "properties": {
      "sent": { "type": "boolean", "description": "是否发送成功" },
      "type": { "type": "string", "description": "事件类型" },
      "target": { "type": "string", "description": "发送目标模式" },
      "targetUserId": { "type": "string", "description": "目标用户 ID" },
      "eventId": { "type": "string", "description": "事件 ID" },
      "payload": { "type": "object", "description": "发送的事件负载" }
    }
  }
}
