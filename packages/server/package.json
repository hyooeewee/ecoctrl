{
  "name": "@ecoctrl/server",
  "version": "0.4.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.ts",
    "build": "pnpm clean && rolldown -c",
    "build:watch": "pnpm clean && rolldown -c -w",
    "preview": "NODE_ENV=staging pnpm build && cp .env.local dist/ && cd dist && pnpm install --prod && node dist/index.js",
    "start": "NODE_ENV=production pnpm build && cp .env.local dist/ && cd dist && npm install --prod && pm2 start ecoctrl.config.cjs",
    "clean": "rimraf dist",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:init": "dotenv -e .env.local -- tsx scripts/init.ts",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:reset": "dotenv -e .env.local -- tsx scripts/reset.ts",
    "db:drop:db": "dotenv -e .env.local -- tsx scripts/drop.ts",
    "db:refresh": "pnpm db:drop:db && pnpm db:push && pnpm db:seed && pnpm db:studio",
    "db:squash": "dotenv -e .env.local -- tsx scripts/squash.ts",
    "db:drop": "drizzle-kit drop",
    "env:overwrite": "tsx ../../packages/shared/scripts/gen-env-example.ts -y",
    "env:check": "tsx ../../packages/shared/scripts/gen-env-example.ts --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "jsep": "^1.4.0",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.37.0",
    "pg-boss": "^12.18.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "rolldown": "1.0.0-rc.16",
    "rotating-file-stream": "^3.2.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@ecoctrl/shared": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "catalog:",
    "@types/pino-pretty": "^5.0.0",
    "@types/unzipper": "^0.10.11",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "picocolors": "^1.1.1",
    "pm2": "^6.0.14",
    "rimraf": "^6.1.3",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  }
}
