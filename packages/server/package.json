{
  "name": "@ecoctrl/server",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch index.ts",
    "build": "pnpm clean && rolldown -c",
    "build:watch": "pnpm clean && rolldown -c -w",
    "preview": "NODE_ENV=staging pnpm build && cp .env.local dist/ && cd dist && pnpm install --prod && node dist/index.js",
    "start": "NODE_ENV=production pnpm build && cp .env.local dist/ && cd dist && npm install --prod && pm2 start ecoctrl.config.cjs",
    "clean": "rimraf dist",
    "check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "db:reset": "dotenv -e .env.local -- tsx scripts/reset.ts",
    "db:drop:db": "dotenv -e .env.local -- tsx scripts/drop.ts",
    "db:refresh": "pnpm db:drop:db && pnpm db:push && pnpm db:seed && pnpm db:studio",
    "db:drop": "drizzle-kit drop",
    "env:sync": "node ../../packages/shared/scripts/gen-env-example.mjs",
    "env:check": "node ../../packages/shared/scripts/gen-env-example.mjs --check"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.9",
    "rolldown": "1.0.0-rc.16",
    "unzipper": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ecoctrl/shared": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "catalog:",
    "@types/unzipper": "^0.10.11",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "pm2": "^6.0.14",
    "rimraf": "^6.1.3",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
