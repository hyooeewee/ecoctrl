# ============================================
# Core Server
# ============================================
PORT=3000
HOST=0.0.0.0

JWT_SECRET=<replace-this-with-a-random-string>

# ============================================
# Logging
# ============================================
LOG_LEVEL=warn # debug | info | warn | error
LOG_DESTINATION=both # stdout | file | both
LOG_DIR=./logs # absolute or relative path
LOG_PRETTY=true # true | false (development only)
LOG_ROTATE_INTERVAL=1d # 1d | 7d | 1h
LOG_MAX_DAYS=30 # number of days to retain

# ============================================
# Database
# ============================================
DATABASE_URL=

# ============================================
# External Services — IoT
# ============================================
BASE_URL=
APP_ID=

# ============================================
# External Services — Weather
# ============================================
OPENWEATHER_API_KEY=
WEATHER_LAT=39.9042
WEATHER_LNG=116.4074
WEATHER_LOCATION=Beijing

# ============================================
# External Services — Email
# ============================================
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# ============================================
# External Services — OAuth
# ============================================
WECHAT_APP_ID=
WECHAT_APP_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ============================================
# External Services — AI
# ============================================
AI_PROVIDER=openai
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=<your-key-here>
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free
