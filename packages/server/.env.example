# ============================================
# Core Server
# ============================================
# production | development
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

JWT_SECRET=<replace-this-with-a-random-string>

# ============================================
# Logging
# ============================================
# debug | info | warn | error
LOG_LEVEL=warn
# stdout | file | both
LOG_DESTINATION=both
# absolute or relative path
LOG_DIR=./logs
# true | false (development only)
LOG_PRETTY=true
# 1d | 7d | 1h
LOG_ROTATE_INTERVAL=1d
# number of days to retain
LOG_MAX_DAYS=30

# ============================================
# Database
# ============================================
DATABASE_URL=

# ============================================
# External Services — IoT
# ============================================
BASE_URL=
APP_ID=

# ============================================
# External Services — Weather
# ============================================
OPENWEATHER_API_KEY=
WEATHER_LAT=39.9042
WEATHER_LNG=116.4074
WEATHER_LOCATION=Beijing

# ============================================
# External Services — Email
# ============================================
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true

# ============================================
# External Services — OAuth
# ============================================
WECHAT_APP_ID=
WECHAT_APP_SECRET=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ============================================
# External Services — AI
# ============================================
AI_PROVIDER=openai
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=<your-key-here>
AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ============================================
# Object Storage (S3-compatible)
# ============================================
# Provider: minio (self-hosted) | local (dev only)
STORAGE_PROVIDER=minio

# S3-compatible endpoint (MinIO internal address for Docker, localhost for dev)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=ecoctrl
S3_SECRET_KEY=ecoctrl_secret
S3_BUCKET_FILES=ecoctrl-files
S3_BUCKET_MODELS=ecoctrl-models
S3_BUCKET_PLUGINS=ecoctrl-nodes
S3_BUCKET_PETS=ecoctrl-pets
# true for MinIO, false for AWS S3
S3_FORCE_PATH_STYLE=true

VITEST_DATABASE_URL=