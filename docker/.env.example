# Docker Compose environment variables
# Copy this file to .env.local and fill in your secrets.
#
# Usage:
#   cp docker/.env.example docker/.env.local
#   docker compose -f docker/compose.yml up --build

# JWT secret used by the Fastify server.
# Change this to a strong random string in production.
JWT_SECRET=ecoctrl-jwt-secret-change-in-production

# External API credentials (optional — used by server for third-party integrations)
BASE_URL=
APP_ID=
