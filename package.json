{
  "name": "ecoctrl",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @ecoctrl/web dev",
    "dev:admin": "pnpm --filter @ecoctrl/admin dev",
    "dev:server": "pnpm --filter @ecoctrl/server dev",
    "dev": "pnpm -r --parallel --if-present --filter=!@ecoctrl/docs dev",
    "build:web": "pnpm --filter @ecoctrl/web build",
    "build:admin": "pnpm --filter @ecoctrl/admin build",
    "build:server": "pnpm --filter @ecoctrl/server build",
    "build": "pnpm -r --if-present build",
    "preview": "pnpm -r --parallel --if-present preview",
    "start": "pnpm -r --parallel --if-present start",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "format": "vp fmt -c $(pwd)/.oxfmtrc.json",
    "format:check": "vp fmt -c $(pwd)/.oxfmtrc.json --check",
    "check": "pnpm format:check && pnpm lint",
    "check:fix": "pnpm format && pnpm lint:fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "node scripts/release-tag.js",
    "prepare": "[ -n \"$CI\" ] || husky",
    "sync:env": "pnpm -r --if-present env:sync",
    "sync:env:check": "pnpm -r --if-present env:check",
    "test": "pnpm -r --if-present test",
    "test:watch": "pnpm -r --parallel --if-present test:watch",
    "test:coverage": "pnpm -r --if-present test:coverage"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "vite-plus": "catalog:",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "packageManager": "pnpm@11.1.0"
}
