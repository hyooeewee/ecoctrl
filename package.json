{
  "name": "ecoctrl",
  "private": true,
  "scripts": {
    "dev:ui": "pnpm --filter @ecoctrl/ui dev",
    "dev:web": "pnpm --filter @ecoctrl/web dev",
    "dev:admin": "pnpm --filter @ecoctrl/admin dev",
    "dev:server": "pnpm --filter @ecoctrl/server dev",
    "dev": "pnpm -r --filter=!@ecoctrl/shared --filter=!@ecoctrl/ui dev",
    "build:ui": "pnpm --filter @ecoctrl/ui build",
    "build:web": "pnpm --filter @ecoctrl/web build",
    "build:admin": "pnpm --filter @ecoctrl/admin build",
    "build:server": "pnpm --filter @ecoctrl/server build",
    "build": "pnpm build:ui && pnpm --filter=@ecoctrl/web --filter=@ecoctrl/admin --filter=@ecoctrl/server build",
    "preview": "pnpm --filter=@ecoctrl/web --filter=@ecoctrl/admin --filter=@ecoctrl/server preview",
    "check": "pnpm -r check",
    "check:fix": "pnpm --filter @ecoctrl/web check:fix && pnpm --filter @ecoctrl/admin check:fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset tag"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
