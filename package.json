{
  "name": "ecoctrl",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @ecoctrl/web dev",
    "dev:admin": "pnpm --filter @ecoctrl/admin dev",
    "dev:server": "pnpm --filter @ecoctrl/server dev",
    "dev": "pnpm -r --parallel --if-present dev",
    "build:web": "pnpm --filter @ecoctrl/web build",
    "build:admin": "pnpm --filter @ecoctrl/admin build",
    "build:server": "pnpm --filter @ecoctrl/server build",
    "build": "pnpm -r --if-present build",
    "preview": "pnpm -r --parallel --if-present preview",
    "start": "pnpm -r --parallel --if-present start",
    "check": "pnpm -r check",
    "check:fix": "pnpm -r --if-present check:fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset tag",
    "prepare": "husky",
    "sync:env": "pnpm -r --if-present env:sync",
    "sync:env:check": "pnpm -r --if-present env:check"
  },
  "packageManager": "pnpm@10.33.1",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7"
  }
}
