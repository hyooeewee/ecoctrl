# Skip in CI or when HUSKY is disabled
if [ "$HUSKY" = "0" ] || [ -n "$CI" ]; then
  exit 0
fi

pnpm env:sync
git add apps/*/.env.example packages/*/.env.example

if [ -f "docker/.env.local" ]; then
  uv run scripts/generate-compose.py --all
  git add docker/compose.yaml docker/compose.dev.yaml docker/compose.build.yaml
fi
