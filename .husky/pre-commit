pnpm sync:env
git add apps/*/.env.example packages/*/.env.example

# Only process files that vp can handle, so we don't hit "no target file" errors.
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|css|html|md)$' | paste -sd " " -)

if [ -n "$STAGED" ]; then
  vp fmt -c "$(pwd)/.oxfmtrc.json" --write $STAGED
  vp lint --fix $STAGED
  git add $STAGED
fi
