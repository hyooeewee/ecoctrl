# Skip in CI or when HUSKY is disabled
if [ "$HUSKY" = "0" ] || [ -n "$CI" ]; then
  exit 0
fi

# Non-interactively sync .env.example files (avoid confirm prompts blocking pre-commit)
for dir in packages/server apps/web apps/admin; do
  if [ -f "$dir/.env.local" ]; then
    pnpm exec tsx packages/shared/scripts/gen-env-example.ts "$dir/.env.local" -y
  fi
done
git add apps/*/.env.example packages/*/.env.example

STAGED=$(git diff --cached --name-only --diff-filter=ACM | paste -sd " " -)
[ -z "$STAGED" ] && exit 0

# vp fmt: exit 2 means "no supported files" — treat as success.
bash -c "vp fmt -c '$(pwd)/.oxfmtrc.json' --write $STAGED; ec=\$?; [ \$ec -eq 0 ] || [ \$ec -eq 2 ] || exit \$ec"

# vp lint: ignore exit 1 when no supported files are found.
LINT_OUT=$(bash -c "vp lint --fix $STAGED 2>&1") || true
LINT_EC=$?
if [ $LINT_EC -ne 0 ] && echo "$LINT_OUT" | grep -q "No files found"; then
  LINT_EC=0
fi
[ $LINT_EC -eq 0 ] || { echo "$LINT_OUT"; exit $LINT_EC; }

git add $STAGED
